# Copy to .env and fill in. The .env file is gitignored — never commit real secrets.
# Settings are read from the environment and from this file (env vars take precedence).

# --- Authentication (at least one token; WIKI_TOKEN takes precedence when both are set) ---
# Yandex OAuth token for the Wiki API
WIKI_TOKEN=
# Or an IAM token (Yandex Cloud organizations)
#WIKI_IAM_TOKEN=

# --- Organization (exactly one) ---
# Yandex 360 organization id
WIKI_ORG_ID=
# Or a Yandex Cloud organization id
#WIKI_CLOUD_ORG_ID=

# --- Safety ---
# true disables all write tools (recommended for experiments against a production wiki)
WIKI_READ_ONLY=true

# --- Transport ---
# stdio (default) | sse | streamable-http
#TRANSPORT=stdio
#HOST=0.0.0.0
#PORT=8000

# --- Logging (stderr) ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL; DEBUG additionally logs Wiki API requests
#LOG_LEVEL=INFO

# --- Wiki endpoints (defaults are fine for wiki.yandex.ru) ---
#WIKI_API_BASE_URL=https://api.wiki.yandex.net
#WIKI_WEB_BASE_URL=https://wiki.yandex.ru
# OAuth | Bearer — Authorization header scheme for WIKI_TOKEN
#WIKI_AUTH_SCHEME=OAuth

# --- MCP OAuth provider (multi-user HTTP deployments only; not needed for local stdio) ---
#OAUTH_ENABLED=false
# memory | redis
#OAUTH_STORE=memory
#OAUTH_SERVER_URL=https://oauth.yandex.ru
#OAUTH_USE_SCOPES=true
#OAUTH_CLIENT_ID=
#OAUTH_CLIENT_SECRET=
# Public URL of this MCP server (used for OAuth callbacks)
#MCP_SERVER_PUBLIC_URL=
# Comma-separated base64-encoded 32-byte keys (required for OAUTH_STORE=redis)
#OAUTH_ENCRYPTION_KEYS=

# --- Redis (only used when OAUTH_ENABLED=true and OAUTH_STORE=redis) ---
#REDIS_ENDPOINT=localhost
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=
#REDIS_POOL_MAX_SIZE=10
